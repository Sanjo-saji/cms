{
  "expo": {
    "name": "cmsx",
    "slug": "cmsx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/homeicons/cmslogo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gladvin.cmsx"
    },
    "android": {
      "permissions": [
        "INTERNET",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO"
      ],
      "requestLegacyExternalStorage": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/homeicons/cmslogo.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gladvin.cmsx"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/homeicons/cmslogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/homeicons/cmslogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "1bb07d13-66d8-4cd4-b211-df25d9f8e220"
      }
    },
    "owner": "gladvin"
  }
}
